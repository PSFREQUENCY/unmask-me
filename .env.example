# UNMASK ME — environment variables
#
# Gemma 4 inference. The app prefers LOCAL inference via Ollama. The cloud
# key is only used as a fallback when no local gemma model is found and the
# user has explicitly granted cloud routing.
GEMINI_API_KEY="your-google-ai-studio-key"
VITE_GEMINI_API_KEY="your-google-ai-studio-key"

# Where Ollama is reachable for local Gemma 4 (E2B/E4B class).
# Pull a model with:    ollama pull gemma4:4b
# Until Gemma 4 ships:  ollama pull gemma3:4b  (lib auto-detects)
VITE_OLLAMA_BASE_URL="http://localhost:11434"

# Google Maps Platform key. RESTRICT THIS KEY:
#   - HTTP referrer restriction: your live URL + http://localhost:3000
#   - API restriction: enable ONLY "Maps JavaScript API" and "Places API (new)"
#   - Quota cap: set a daily request cap in Cloud Console
GOOGLE_MAPS_PLATFORM_KEY=""

# Live demo URL — AI Studio injects this in production.
APP_URL=""

# Admin secret. The hidden admin dot in the settings panel asks for this.
# Set it locally before deploying so only you can open the admin dashboard.
VITE_ADMIN_SECRET="change-me"
